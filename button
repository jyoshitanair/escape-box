#include <Wire.h>
#define SLAVE_ADDR 9 
int button1pin = 7;
int button2pin = 8;
void setup() {
    Wire.begin();
    pinMode(button1pin,OUTPUT);
    pinMode(button2pin,OUTPUT);
    Serial.begin(9600);
}
void loop() {
    Wire.requestFrom(SLAVE_ADDR,1);
    if (Wire.available()){
      int val = Wire.read();
      Serial.println(val);
    }
    delay(1000);
    Wire.beginTransmission(SLAVE_ADDR);
    Wire.write(55); //what value to send 
    Wire.endTransmission();
    delay(3000);
    //button code
    if(digitalRead(button1pin) == 0){
      Serial.println("off");
    }
}
