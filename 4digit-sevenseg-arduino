#include "SevSeg.h"
#include <Servo.h>
SevSeg sevseg;
Servo myServo;
//values
int button1value = 0; 
int button2value = 0;
int button3value = 0;
int button4value = 0;
//pins
int servopin = A3; 
int ledpin = A2;
int button1pin = A4;
int button2pin = A5;
int button3pin = A0;
int button4pin = A1;
//button1
static bool previous1 = HIGH;
static bool current1 = HIGH;
unsigned long lastClickTime1;
//button2
static bool previous2 = HIGH;
static bool current2 = HIGH;
unsigned long lastClickTime2;
//button3
static bool previous3 = HIGH;
static bool current3 = HIGH;
unsigned long lastClickTime3;
//button4
static bool previous4 = HIGH;
static bool current4 = HIGH;
unsigned long lastClickTime4;
//other
bool done = false; 
bool canChange = true;
int finalValue = 0000; 
 //Initiate a seven segment controller object
//can not use 0 and 1 pins

void setup() {
    //buttons 
    pinMode(button1pin,INPUT_PULLUP);
    pinMode(button2pin,INPUT_PULLUP);
    pinMode(button3pin,INPUT_PULLUP);
    pinMode(button4pin,INPUT_PULLUP);
    pinMode(ledpin, OUTPUT);
    myServo.attach(servopin);
    byte numDigits = 4;  
    byte digitPins[] = {2, 3, 4, 5};
    byte segmentPins[] = {6, 7, 8, 10, 9, 12, 11, 13};
    bool resistorsOnSegments = 0; 
    // variable above indicates that 4 resistors were placed on the digit pins.
    // set variable to 1 if you want to use 8 resistors on the segment pins.
    sevseg.begin(COMMON_CATHODE, numDigits, digitPins, segmentPins, resistorsOnSegments);
    sevseg.setBrightness(90);
    sevseg.setNumber(0000, 4);
    myServo.write(0);
}
void loop() {
    //check
    finalValue = (button1value*1000) + (button2value *100) + (button3value *10) +button4value;
    if (finalValue==8888 && !done){
      Serial.println("YOU WIN");
      digitalWrite(ledpin, HIGH);
      //servo stuff
      myServo.write(180);
      done = true;
      canChange = false;
    }
    sevseg.setNumber(finalValue, 4);
    if (canChange){
      //button 1 
      current1 = digitalRead(button1pin);
      if(current1 == LOW && previous1 == HIGH && millis() -lastClickTime1 > 50){
        lastClickTime1 = millis();
        if (button1value != 9){
          button1value += 1; 
        }else{
          button1value = 0; 
        }
      }
      previous1 =current1;
      //button 2 
      current2 = digitalRead(button2pin);
      if(current2 == LOW && previous2 == HIGH && millis() -lastClickTime2 > 50){
        lastClickTime2 = millis();
        if (button2value != 9){
          button2value += 1; 
        }else{
          button2value = 0; 
        }
      }
      previous2 =current2;
      //button 3 
      current3 = digitalRead(button3pin);
      if(current3 == LOW && previous3 == HIGH && millis() -lastClickTime3 > 50){
        lastClickTime3 = millis();
        if (button3value != 9){
          button3value += 1; 
        }else{
          button3value = 0; 
        }
      }
      previous3 =current3;
      //button 4 
      current4 = digitalRead(button4pin);
      if(current4 == LOW && previous4 == HIGH && millis() -lastClickTime4 > 50){
        lastClickTime4 = millis();
        if (button4value != 9){
          button4value += 1; 
        }else{
          button4value = 0; 
        }
      }
      previous4 =current4;
    }
  sevseg.refreshDisplay(); // Must run repeatedly
}
