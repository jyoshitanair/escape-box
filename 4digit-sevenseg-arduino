#include "SevSeg.h"
SevSeg sevseg;
int button1pin = A1;
int button2pin = A0;
int button3pin = A5;
int button4pin = A4;
//button1
static bool previous1 = HIGH;
static bool current1 = HIGH;
//button2
static bool previous2 = HIGH;
static bool current2 = HIGH;
//button3
static bool previous3 = HIGH;
static bool current3 = HIGH;
//button4
static bool previous4 = HIGH;
static bool current4 = HIGH;
 //Initiate a seven segment controller object
//can not use 0 and 1 pins

void setup() {
    //buttons 
    pinMode(button1pin,INPUT_PULLUP);
    pinMode(button2pin,INPUT_PULLUP);
    pinMode(button3pin,INPUT_PULLUP);
    pinMode(button4pin,INPUT_PULLUP);
    Serial.begin(9600);
    byte numDigits = 4;  
    byte digitPins[] = {2, 3, 4, 5};
    byte segmentPins[] = {6, 7, 8, 9, 10, 12, 11, 13};
    bool resistorsOnSegments = 0; 
    // variable above indicates that 4 resistors were placed on the digit pins.
    // set variable to 1 if you want to use 8 resistors on the segment pins.
    sevseg.begin(COMMON_CATHODE, numDigits, digitPins, segmentPins, resistorsOnSegments);
    sevseg.setBrightness(90);
    sevseg.setNumber(2222, 4);
    Serial.begin(9600);
}
void loop() {
    //button 1 
    current1 = digitalRead(button1pin);
    if(current1 == LOW && previous1 == HIGH){
      Serial.println("button1_on");
    }
    if(current1 == HIGH && previous1 == LOW){
      Serial.println("button1_off");
    }
    previous1 =current1;
     //button 2 
    current2 = digitalRead(button2pin);
    if(current2 == LOW && previous2 == HIGH){
      Serial.println("button2_on");
    }
    if(current2 == HIGH && previous2 == LOW){
      Serial.println("button2_off");
    }
    previous2 =current2;
     //button 3 
    current3 = digitalRead(button3pin);
    if(current3 == LOW && previous3 == HIGH){
      Serial.println("button3_on");
    }
    if(current3 == HIGH && previous3 == LOW){
      Serial.println("button3_off");
    }
    previous3 =current3;
     //button 4 
    current4 = digitalRead(button4pin);
    if(current4 == LOW && previous4 == HIGH){
      Serial.println("button4_on");
    }
    if(current4 == HIGH && previous4 == LOW){
      Serial.println("button4_off");
    }
    previous4 =current4;
    sevseg.refreshDisplay(); // Must run repeatedly
}
